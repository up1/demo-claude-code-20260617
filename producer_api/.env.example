# HTTP server
PORT=8080
SERVICE_NAME=producer-api

# Redis (duplicate detection)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Time-to-live for the dedup key (Go duration, e.g. 24h, 30m).
DEDUP_TTL=24h

# RabbitMQ (AMQP 1.0, requires RabbitMQ >= 4.0)
RABBITMQ_URI=amqp://guest:guest@localhost:5672/

# OpenTelemetry. Leave empty to print traces to stdout; set to an OTLP/gRPC
# collector endpoint (host:port) to export there, e.g. localhost:4317.
OTEL_EXPORTER_OTLP_ENDPOINT=
